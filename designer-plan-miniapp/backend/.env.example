# 后台管理令牌（前后端一致）
ADMIN_TOKEN=kwc-admin-dev

# 支付模式: mock | wechat（兼容 real=wechat）
PAY_MODE=mock

# 微信登录（配置后将走真实 code2session）
WECHAT_APPID=
WECHAT_APP_SECRET=

# 微信支付（退款）配置
WECHAT_PAY_MCHID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PRIVATE_KEY_PEM=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_REFUND_NOTIFY_URL=

# 微信退款回调验签（至少配置一种平台公钥来源）
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PEM=
WECHAT_PAY_PLATFORM_CERT_PATH=

# 可选：联调时临时关闭回调验签/时间戳检查（生产请保持 false）
WECHAT_PAY_SKIP_NOTIFY_VERIFY=false
WECHAT_PAY_SKIP_NOTIFY_TS_CHECK=false

# 可选：微信支付 API 地址，默认官方
WECHAT_PAY_API_BASE=https://api.mch.weixin.qq.com

# 开发模式 openid 盐
DEV_OPENID_SALT=kwc-dev-salt
