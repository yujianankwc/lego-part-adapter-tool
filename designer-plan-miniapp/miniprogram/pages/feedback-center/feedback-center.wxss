.picker,
.input,
.textarea {
  border: 1rpx solid #ccd8f7;
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
  background: #f9fbff;
  margin-bottom: 12rpx;
}

.textarea {
  min-height: 180rpx;
  width: 100%;
  box-sizing: border-box;
}

.img-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.img-btn {
  margin: 0;
  min-width: 220rpx;
  width: auto;
}

.img-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.img-item {
  position: relative;
}

.img {
  width: 164rpx;
  height: 164rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d8e3fb;
}

.img-del {
  position: absolute;
  right: 4rpx;
  top: 4rpx;
  font-size: 18rpx;
  line-height: 1;
  padding: 6rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border: none;
}

.item {
  border: 1rpx solid #dce5fa;
  border-radius: 14rpx;
  padding: 14rpx;
  margin-bottom: 12rpx;
  background: #f8fbff;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.content {
  color: #1f2a44;
  line-height: 1.7;
  word-break: break-word;
}

.reply {
  margin-top: 10rpx;
  color: #1246b6;
  background: #ebf2ff;
  border-radius: 10rpx;
  padding: 10rpx 12rpx;
}

.empty {
  color: var(--muted-text);
}
