<view class="container">
  <view class="card">
    <view class="section-title">我的订单</view>
    <view class="section-desc">支持按订单状态与时间范围筛选查看。</view>

    <view class="order-tabs">
      <view
        class="order-tab {{orderTab === item.key ? 'active' : ''}}"
        wx:for="{{orderTabs}}"
        wx:key="key"
        data-tab="{{item.key}}"
        bindtap="handleSwitchOrderTab"
      >
        {{item.label}}
      </view>
    </view>

    <view class="period-tabs">
      <view
        class="period-tab {{periodDays === item.days ? 'active' : ''}}"
        wx:for="{{periodOptions}}"
        wx:key="days"
        data-days="{{item.days}}"
        bindtap="handleSwitchPeriod"
      >
        {{item.label}}
      </view>
    </view>

    <view class="empty" wx:if="{{orders.length === 0 && !ordersLoading}}">当前筛选下暂无订单。</view>

    <view class="order-item" wx:for="{{orders}}" wx:key="orderId">
      <view class="order-top">
        <text class="order-id">{{item.orderId}}</text>
        <text class="status">{{item.status}}</text>
      </view>
      <view class="muted">{{item.saleModeText}} · {{item.workName}} · {{item.skuName}} x{{item.quantity}}</view>
      <view class="muted">总金额：￥{{item.totalAmount}} · 实付：￥{{item.paidAmount}} · 退款：￥{{item.refundAmount}}</view>
      <view class="muted">支付状态：{{item.payStatus}} · 退款状态：{{item.refundStatus}}</view>
      <view class="muted">下单：{{item.createdAt}} · 支付：{{item.paidAt || '-'}}</view>
      <view class="muted" wx:if="{{item.refundedAt}}">退款时间：{{item.refundedAt}}</view>
      <view class="muted" wx:if="{{item.refundReason}}">退款原因：{{item.refundReason}}</view>
    </view>

    <button class="secondary-btn load-more-btn" wx:if="{{ordersHasMore && !ordersLoading}}" bindtap="handleLoadMoreOrders">加载更多</button>
    <view class="muted" wx:if="{{ordersLoading}}">订单加载中...</view>
    <view class="muted" wx:if="{{!ordersHasMore && orders.length > 0}}">已加载全部订单</view>
  </view>
</view>
