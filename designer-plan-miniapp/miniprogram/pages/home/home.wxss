.hero {
  background: linear-gradient(155deg, #102b66 0%, #163d83 55%, #1f4f9d 100%);
  color: #ffffff;
  overflow: hidden;
  position: relative;
}

.hero::before {
  content: '';
  position: absolute;
  right: -120rpx;
  top: -120rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-cover {
  width: calc(100% + 44rpx);
  height: 420rpx;
  margin: -24rpx -24rpx 20rpx;
  border-radius: 24rpx 24rpx 14rpx 14rpx;
}

.hero-tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  font-size: 21rpx;
  padding: 8rpx 15rpx;
  position: relative;
  z-index: 1;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.3;
  word-break: break-word;
  position: relative;
  z-index: 1;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.84);
  word-break: break-word;
  position: relative;
  z-index: 1;
}

.hero-gallery {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.hero-gallery-item {
  width: 31.8%;
  height: 112rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
}

.countdown-wrap {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  position: relative;
  z-index: 1;
}

.count-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.count-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  word-break: break-word;
}

.progress-track {
  margin: 12rpx 0;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  overflow: hidden;
}

.progress-fill {
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff9d3d, #ffd56a);
}

.crowd-metrics {
  margin: 14rpx 0 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.metric {
  width: 31.8%;
  background: rgba(255, 255, 255, 0.17);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  border-radius: 12rpx;
  padding: 12rpx 8rpx;
  text-align: center;
}

.metric-num {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffe7aa;
}

.metric-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.75);
}

.count-state {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.86);
}

.hero-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 14rpx;
  position: relative;
  z-index: 1;
}

.hero-actions .primary-btn,
.hero-actions .secondary-btn {
  flex: 1;
  width: auto;
}

.hero-actions .secondary-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.4);
}

.chips {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.highlight-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f1f5ff;
  color: #2b458c;
  border: 1rpx solid #d7e2fb;
  font-size: 24rpx;
  max-width: 100%;
  word-break: break-word;
}

.sub-title {
  margin-top: 18rpx;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  color: var(--brand-blue);
  font-weight: 700;
}

.line-item {
  margin-bottom: 10rpx;
  color: var(--muted-text);
  line-height: 1.7;
}

.apply-btn {
  margin-top: 20rpx;
}
