.row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e8eefb;
}

.row:last-child {
  border-bottom: none;
}

.row text {
  flex: 1;
  min-width: 0;
  line-height: 1.55;
  color: #24324d;
}

.action-btn {
  margin-top: 12rpx;
}

.danger-btn {
  background: #fff1f1;
  color: #b62525;
  border: 1rpx solid #efb1b1;
  border-radius: 999rpx;
  font-weight: 700;
}
